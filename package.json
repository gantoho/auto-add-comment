{
  "name": "little-horse",
  "displayName": "Little Horse",
  "description": "Auto add custom comment to files on save",
  "version": "0.0.6",
  "icon": "images/icon.webp",
  "publisher": "ganto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gantoho/auto-add-comment.git"
  },
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "auto-add-comment.toggle",
        "title": "Toggle Auto Add Comment"
      }
    ],
    "configuration": {
      "title": "File Auto Comment",
      "properties": {
        "fileAutoComment.commentMarker": {
          "type": "string",
          "default": "project",
          "description": "Unique marker for identifying auto-generated comments (used in templates with {marker})."
        },
        "fileAutoComment.timeOffset": {
          "type": "number",
          "default": 5,
          "description": "Time offset in minutes (positive = forward, negative = backward). e.g. 5 = 5 minutes later, -3 = 3 minutes earlier."
        },
        "fileAutoComment.templates": {
          "type": "object",
          "default": {},
          "description": "Comment templates for different file types. Use {time} as placeholder for current time (format: YYYY-MM-DD HH:mm:ss)",
          "additionalProperties": {
            "type": "string"
          }
        },
        "fileAutoComment.enabledTemplates": {
          "type": "object",
          "default": {},
          "description": "Enabled status for each template",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "fileAutoComment.workspacePath": {
          "type": "string",
          "default": "",
          "description": "Workspace path (absolute) where the extension should be active. If empty, extension works in all workspaces."
        },
        "fileAutoComment.enableWorkspaceFilter": {
          "type": "boolean",
          "default": false,
          "description": "Enable workspace filtering. When enabled, extension only works in the specified workspace path."
        }
      }
    },
    "menus": {
      "statusBar": [
        {
          "command": "auto-add-comment.toggle",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "diff": "^8.0.3"
  }
}
